generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role{
  CUSTOMER
  AGENT
  MERCHANT
  ADMIN
}

enum KycStatus{
  PENDING
  APPROVED
  REJECTED
}

enum AccountStatus{
  ACTIVE
  LOCKED
  SUSPENDED
}

enum WalletType{
  PERSONAL
  AGENT
  MERCHANT
  SYSTEM
}

enum TransactionType{
  SEND_MONEY
  CASH_IN
  CASH_OUT
  PAYMENT
  ADD_MONEY
}

enum TransactionStatus{
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

enum EntryType{
  DEBIT
  CREDIT
}

model User{
  id  String  @id @default(uuid())  @db.Uuid
  phone String  @unique
  pin String

  role Role @default(CUSTOMER)
  kycStatus KycStatus @default(PENDING)
  status  AccountStatus @default(ACTIVE)

  nidNumber String? @unique
  fullName  String?

  createdAT DateTime  @default(now())
  updatedAT DateTime  @updatedAt

  wallet  Wallet?
  trustDevices  TrustDevice[]

  @@map("users")
}

model Wallet{
  id  String  @id @default(uuid())  @db.Uuid

  userId  String? @unique @db.Uuid
  user  User?  @relation(fields: [userId],references: [id], onDelete: Restrict)

  type  WalletType  @default(PERSONAL)
  isActive  Boolean @default(true)

  balance BigInt @default(0)
  currency  String  @default("BDT")

  //Optimistic Concurrency Control check
  version Int @default(1)
  
  createdAT DateTime  @default(now())
  updatedAT DateTime  @updatedAt

  sentTransactions Transaction[]  @relation("OutGoingTransactions")
  recivedTransactions Transaction[] @relation("IncomingTransactions")

  ledgerEntries LedgerEntry[]

  @@map("wallets")
}

model Transaction{
  id  String  @id @default(uuid())  @db.Uuid
  // The public readable Id
  trxId String  @unique

  //Strict Idempotency. Client generate this UUID.
  idempotencyKey  String  @unique @db.Uuid

  type  TransactionType 
  status  TransactionStatus @default(PENDING)

  amount  BigInt
  fee Int @default(0)
  reference String?

  // Relation 1: The Wallet sending the money
  senderWalletId  String  @db.Uuid
  senderWallet  Wallet  @relation("OutGoingTransactions",fields: [senderWalletId],references:[id],onDelete: Restrict)

  // Relation 2: The Wallet receiving money
  receiverWalletId  String  @db.Uuid
  receiverWallet  Wallet @relation("IncomingTransactions",fields: [receiverWalletId],references: [id],onDelete: Restrict)

  entries LedgerEntry[]

  createdAT DateTime  @default(now())
  updatedAT DateTime  @updatedAt

  @@index([senderWalletId])
  @@index([receiverWalletId])
  @@index([idempotencyKey])
  @@map("transactions")
}

model LedgerEntry{
  id  String  @id @default(uuid())  @db.Uuid

  // Relation 1: Which transaction caused this movement?
  transactionId String  @db.Uuid
  transaction Transaction @relation(fields: [transactionId],references: [id],onDelete: Restrict)

  // Relation 2: Which wallet this money entering/leaving?
  walletId  String  @db.Uuid
  wallet  Wallet  @relation(fields: [walletId],references: [id])

  // The Math: Direction and Amount
  type  EntryType
  amount  BigInt

  // The snapshot of wallet's balance after entry
  balanceAfter  Int

  description String?
  createdAt DateTime  @default(now())

  @@index([walletId,createdAt(sort: Desc)])
  @@index([transactionId])
  @@map("ledger_entries")
}

model TrustDevice{
  id  String  @id @default(uuid())  @db.Uuid
  deviceId  String  @unique

  userId  String  @db.Uuid
  user User @relation(fields: [userId],references: [id])
  
  refreshTokenHash  String?
  isAuthorized  Boolean
  lastUsedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("trusted_devices")
}